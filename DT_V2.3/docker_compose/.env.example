# Image pins (replace latest tags with fixed versions or digests before production)
MYSQL_DB_VERSION=8.0
MYSQL_BOOTSTRAP_IMAGE=mysql:8.0
KEYROCK_IMAGE=lemostiago/custom-keyrock:latest
API_GATEWAY_IMAGE=nginx:alpine
PEP_PROXY_IMAGE=quay.io/fiware/pep-proxy
AUTHZFORCE_IMAGE=fiware/authzforce-ce-server:12.0.1
MONGO_IMAGE=mongo:latest
ORION_IMAGE=quay.io/fiware/orion:latest
IOT_AGENT_IMAGE=lemostiago/custom-iotagent:latest
MOSQUITTO_IMAGE=eclipse-mosquitto

# Ports and platform settings
MYSQL_DB_PORT=3306
KEYROCK_PORT=3005
KEYROCK_HTTPS_PORT=3443
IDM_HTTPS_ENABLED=false
PORTAL_BFF_PORT=8001
# On remote/server deployments, replace localhost with your public IP or DNS name.
PORTAL_PUBLIC_BASE_URL=http://localhost:8001
KEYROCK_BROWSER_URL=http://localhost:3005
PORTAL_ORIGIN=http://localhost:8001
TZ=Europe/Lisbon

# Logging
PEP_PROXY_DEBUG=false
PEP_PROXY_LOG_LEVEL=INFO
ORION_LOG_LEVEL=INFO
IOTA_LOG_LEVEL=INFO

# Keyrock and DB identities
KEYROCK_DB_NAME=keyrock
KEYROCK_DB_USER=keyrock
KEYROCK_ADMIN_USERNAME=admin
KEYROCK_ADMIN_EMAIL=admin@example.com
KEYROCK_VIEWER_USERNAME=viewer
KEYROCK_VIEWER_EMAIL=viewer@example.com

# App metadata used by bootstrap
APP_NAME=MTEXNS Secure API
APP_DESCRIPTION=Secured Orion + IoT Agent behind Wilma
# Must match the same host used by PORTAL_PUBLIC_BASE_URL/KEYROCK_BROWSER_URL.
APP_URL=http://localhost:8001
APP_REDIRECT_URI=http://localhost:8001/auth/callback
BFF_ADMIN_ROLE_NAME=Admin

# Secrets (generate locally; do not commit)
KEYROCK_DB_PASS=
KEYROCK_ADMIN_PASS=
KEYROCK_VIEWER_PASS=
BFF_SESSION_SECRET=

# MongoDB credentials — MONGO_ROOT_PASSWORD is auto-generated by prepare-env.ps1
MONGO_ROOT_USERNAME=admin
MONGO_ROOT_PASSWORD=
